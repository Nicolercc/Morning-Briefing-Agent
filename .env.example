# Copy this file to .env and fill in real values.
# Never commit .env.

# Slack delivery.
# Bot tokens usually start with xoxb-. User tokens usually start with xoxp-.
SLACK_BOT_TOKEN=xoxb-your-token-here

# For a channel, use an ID like C0123456789.
# For a DM to yourself, open a DM with the app/user and use that conversation ID.
SLACK_CHANNEL_ID=C0123456789

# Optional, defaults to Morning Briefing Agent.
SLACK_USERNAME=Morning Briefing Agent
