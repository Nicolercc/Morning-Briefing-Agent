# Copy this file to .env and fill in real values.
# Never commit .env.

# Slack delivery.
# Bot tokens usually start with xoxb-. User tokens usually start with xoxp-.
SLACK_BOT_TOKEN=xoxb-your-token-here

# For a channel, use an ID like C0123456789.
# For a DM to yourself, open a DM with the app/user and use that conversation ID.
SLACK_CHANNEL_ID=C0123456789

# Optional, defaults to Morning Briefing Agent.
SLACK_USERNAME=Morning Briefing Agent

# Google/Gmail read access.
# For personal Gmail accounts, use oauth_user. Do not use a service account
# unless this is a Google Workspace domain with domain-wide delegation.
GOOGLE_AUTH_MODE=oauth_user
GOOGLE_OAUTH_CLIENT_FILE=credentials/google_oauth_client.json
GOOGLE_TOKEN_DIR=tokens/google

# Comma-separated account profiles. Each profile gets its own OAuth token file.
GMAIL_ACCOUNT_IDS=personal,job_search,mom

GMAIL_ACCOUNT_PERSONAL_OWNER=you
GMAIL_ACCOUNT_PERSONAL_LABEL=Personal Gmail
GMAIL_ACCOUNT_PERSONAL_TOKEN_FILE=tokens/google/personal.json

GMAIL_ACCOUNT_JOB_SEARCH_OWNER=you
GMAIL_ACCOUNT_JOB_SEARCH_LABEL=Job Search Gmail
GMAIL_ACCOUNT_JOB_SEARCH_TOKEN_FILE=tokens/google/job_search.json

GMAIL_ACCOUNT_MOM_OWNER=mom
GMAIL_ACCOUNT_MOM_LABEL=Mom Gmail
GMAIL_ACCOUNT_MOM_TOKEN_FILE=tokens/google/mom.json

# Only for Google Workspace domain-wide delegation, not normal personal Gmail.
# GOOGLE_SERVICE_ACCOUNT_FILE=credentials/workspace_service_account.json
# GOOGLE_DELEGATED_SUBJECTS=you@yourdomain.com,mom@yourdomain.com
